{
  "name": "ally-ambient-rgb",
  "version": "1.0.0",
  "description": "Real-time ambient lighting — the controller's RGB joystick rings follow the dominant color on screen.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wjames111/ally-ambient-rgb.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "rog-ally",
    "rgb",
    "ambient",
    "lighting",
    "handheld",
    "bazzite"
  ],
  "author": "William James",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wjames111/ally-ambient-rgb/issues"
  },
  "homepage": "https://github.com/wjames111/ally-ambient-rgb#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
